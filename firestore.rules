rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'level', 'xp', 'coins']) &&
             data.userId == request.auth.uid &&
             data.level is number &&
             data.xp is number &&
             data.coins is number;
    }
    
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      // Removed isValidUser(incoming()) from update because we won't strictly enforce unaffected keys for prototyping simplicity.
    }
    
    function isValidTrade(data) {
       return data.keys().hasAll(['id', 'senderId', 'senderName', 'offering', 'requesting', 'timestamp', 'status']) &&
              data.senderId == request.auth.uid &&
              data.id is string && data.id.size() <= 64 &&
              data.senderName is string && data.senderName.size() <= 64 &&
              data.offering is string && data.offering.size() <= 64 &&
              data.requesting is string && data.requesting.size() <= 64 &&
              data.timestamp is number &&
              data.status in ['active', 'completed', 'cancelled'];
    }
    
    match /trades/{tradeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.status == 'active';
      allow create: if isSignedIn() && isValidId(tradeId) && isValidTrade(incoming());
      allow update: if isSignedIn() && (
         (request.auth.uid == existing().senderId && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
         (existing().status == 'active' && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'completed')
      );
    }
  }
}
